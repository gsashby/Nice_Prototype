# Copy to .env and fill in values
# cp .env.example .env

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_trust_center
TIMESCALE_URL=postgresql://postgres:postgres@localhost:5432/ai_trust_center

# Redis
REDIS_URL=redis://localhost:6379/0

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=ai_trust_center

# API
API_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# AI Services
AI_SERVICES_PORT=8001
AI_SERVICES_URL=http://localhost:8001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AI_SERVICES_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8080
